CREATE PROCEDURE [_vender].[SP_GetContacts]
(
    @UserId INT
)
AS
BEGIN
BEGIN TRY

SELECT 
    U.UserId,
    0 AS ContactUserId,
    ISNULL(V.VenderCode, U.UserCode) AS VenderCode,
    U.Email,
    U.UserCode,
    U.LastSeen,
    NULL AS Status,
    GETDATE() AS CreatedAt,

    -- Latest Message
    M.MessageText,
    M.MessageType,
    M.SentAt

FROM [_vender].[User] U

LEFT JOIN [_vender].[Vender] V
    ON U.UserId = V.UserId
    AND V.IsDeleted = 0

-- Latest message between users
OUTER APPLY
(
