        MessageText,
        MessageType,
        SentAt
    FROM [_vender].[Messages] MSG
    WHERE 
        (MSG.SenderId = @UserId AND MSG.ReceiverId = U.UserId)
        OR
        (MSG.SenderId = U.UserId AND MSG.ReceiverId = @UserId)
    ORDER BY MSG.SentAt DESC
) M

WHERE 
    U.UserId <> @UserId
    AND U.IsDeleted = 0

END TRY

BEGIN CATCH
    SELECT ERROR_MESSAGE() AS ErrorMessage
END CATCH

END
