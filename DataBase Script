CREATE PROCEDURE [_vender].[SP_VerifyOtp]
(
    @Email NVARCHAR(255),
    @Otp NVARCHAR(6)
)
AS
BEGIN
    SET NOCOUNT ON;

    IF NOT EXISTS
    (
        SELECT 1
        FROM [_vender].[VenderOtp]
        WHERE Email = @Email
          AND OtpCode = @Otp
          AND IsUsed = 0
          AND ExpiryTime > GETDATE()
    )
    BEGIN
        SELECT 0 AS Status, 'Invalid or Expired OTP' AS Message;
        RETURN;
    END

    UPDATE [_vender].[VenderOtp]
    SET IsUsed = 1
    WHERE Email = @Email
      AND OtpCode = @Otp;

    SELECT 1 AS Status, 'OTP Verified Successfully' AS Message;
END
