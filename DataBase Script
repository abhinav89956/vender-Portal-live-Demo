CREATE PROCEDURE [_vender].[SP_GetAllVenders]
    @SearchVenderCode NVARCHAR(100) = NULL,
    @PageNumber INT = 1,
    @PageSize INT = 10
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        -- Ensure valid paging
        IF @PageNumber < 1 SET @PageNumber = 1;
        IF @PageSize < 1 SET @PageSize = 10;

        DECLARE @Offset INT = (@PageNumber - 1) * @PageSize;
        DECLARE @TotalCount INT;

        -- Get total count
        SELECT @TotalCount = COUNT(*)
        FROM [_vender].[Vender]
        WHERE IsDeleted = 0
          AND (@SearchVenderCode IS NULL OR VenderCode LIKE '%' + @SearchVenderCode + '%');

        
        SELECT
            1 AS Status,
            'Success' AS Message,
            VenderId,
            VenderCode,
            CodeDescription,
            LotVender,
            Email,
            InsertedDate,
            UpdatedDate,
            IsActive,
            IsVerifird,
            IsAgrementSigned,
            IsSignupCompleted,
            @TotalCount AS TotalCount 
        FROM [_vender].[Vender]
        WHERE IsDeleted = 0
          AND (@SearchVenderCode IS NULL OR VenderCode LIKE '%' + @SearchVenderCode + '%')
        ORDER BY InsertedDate DESC
        OFFSET @Offset ROWS
        FETCH NEXT @PageSize ROWS ONLY;

    END TRY
    BEGIN CATCH
       
        DECLARE @ErrorMessage NVARCHAR(4000) = ERROR_MESSAGE();

        SELECT
            0 AS Status,
            'Error: ' + @ErrorMessage AS Message,
            CAST(NULL AS INT) AS VenderId,
            CAST(NULL AS NVARCHAR(100)) AS VenderCode,
            CAST(NULL AS NVARCHAR(200)) AS CodeDescription,
            CAST(NULL AS NVARCHAR(50)) AS LotVender,
            CAST(NULL AS NVARCHAR(100)) AS Email,
            CAST(NULL AS DATETIME) AS InsertedDate,
            CAST(NULL AS DATETIME) AS UpdatedDate,
            CAST(0 AS BIT) AS IsActive,
            CAST(0 AS BIT) AS IsVerifird,
            CAST(0 AS BIT) AS IsAgrementSigned,
            CAST(0 AS BIT) AS IsSignupCompleted,
            0 AS TotalCount;
    END CATCH
END
