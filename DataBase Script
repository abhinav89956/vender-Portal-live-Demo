CREATE PROCEDURE [_vender].[SP_UpdateVender]
    @VenderId INT,
    @VenderCode NVARCHAR(50),
    @CodeDescription NVARCHAR(255),
    @Email NVARCHAR(255),
    @IsActive BIT = NULL 
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRANSACTION;

        DECLARE @ExistingVenderId INT;

        
        IF NOT EXISTS (
            SELECT 1
            FROM [_vender].[Vender]
            WHERE VenderId = @VenderId
        )
        BEGIN
            ROLLBACK TRANSACTION;
            SELECT 0 AS Status, 'Vender not found.' AS Message, NULL AS VenderId;
            RETURN;
        END

        SELECT TOP 1 @ExistingVenderId = VenderId
        FROM [_vender].[Vender]
        WHERE VenderCode = @VenderCode
          AND VenderId <> @VenderId
          AND IsDeleted = 0;

        IF @ExistingVenderId IS NOT NULL
        BEGIN
            ROLLBACK TRANSACTION;
            SELECT 0 AS Status, 'VenderCode already exists.' AS Message, @VenderId AS VenderId;
            RETURN;
        END

       
        SELECT TOP 1 @ExistingVenderId = VenderId
        FROM [_vender].[Vender]
        WHERE Email = @Email
          AND VenderId <> @VenderId
          AND IsDeleted = 0;

        IF @ExistingVenderId IS NOT NULL
        BEGIN
            ROLLBACK TRANSACTION;
            SELECT 0 AS Status, 'Email already exists.' AS Message, @VenderId AS VenderId;
            RETURN;
        END

        
        UPDATE [_vender].[Vender]
        SET
            VenderCode = @VenderCode,
            CodeDescription = @CodeDescription,
            Email = @Email,
            IsActive = COALESCE(@IsActive, IsActive), -- keep old value if null
            UpdatedDate = GETDATE()
        WHERE VenderId = @VenderId;

        COMMIT TRANSACTION;

        SELECT 1 AS Status, 'Vender updated successfully.' AS Message, @VenderId AS VenderId;

    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0
            ROLLBACK TRANSACTION;

        SELECT 0 AS Status, ERROR_MESSAGE() AS Message, NULL AS VenderId;
    END CATCH
END
GO
