CREATE PROCEDURE [_vender].[SP_UpdateMessageStatus]
(
    @MessageId INT,
    @ReceiverId INT,
    @IsSent BIT = NULL,
    @IsDelivered BIT = NULL,
    @IsSeen BIT = NULL,
    @SeenAt DATETIME = NULL
)
AS
BEGIN
