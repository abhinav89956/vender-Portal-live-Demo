CREATE PROCEDURE [_vender].[SP_UserLogin]
    @Email NVARCHAR(255),
    @Password NVARCHAR(500)
AS
BEGIN
    SET NOCOUNT ON;

    SELECT 
        1 AS Status,
        u.UserId,
        u.Email,
        u.IsActive,
        v.VenderCode,
        'Login successful' AS Message
    FROM [_vender].[User] u
    LEFT JOIN [_vender].[Vender] v 
        ON v.Email = u.Email     -- ✅ FIXED JOIN
    WHERE u.Email = @Email
      AND u.PaswdHash = CONVERT(NVARCHAR(500), HASHBYTES('SHA2_256', @Password), 2)
      AND u.IsDeleted = 0;

    IF @@ROWCOUNT = 0
    BEGIN
        SELECT 
            0 AS Status,
            NULL AS UserId,
            @Email AS Email,
            NULL AS IsActive,
            NULL AS VenderCode,
            'Invalid email or password' AS Message;
    END
END
