CREATE PROCEDURE [_vender].[SP_RegisterUser]
    @Email NVARCHAR(255),
    @Password NVARCHAR(500),
    @VenderCode NVARCHAR(50)
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @UserId INT;
    DECLARE @IsActive BIT;
    DECLARE @VendorActive BIT;

    -- Token related
    DECLARE @Token NVARCHAR(MAX);
    DECLARE @ExpiryHours INT;
    DECLARE @ExpiryDate DATETIME;

    ------------------------------
    -- 1. Check Vendor exists & active
    ------------------------------
    SELECT @VendorActive = IsActive
    FROM [_vender].[Vender]
    WHERE Email = @Email
      AND VenderCode = @VenderCode
      AND IsDeleted = 0;

    IF @VendorActive IS NULL
    BEGIN
        SELECT 
            0 AS Status,
            NULL AS UserId,
            @Email AS Email,
            NULL AS Token,
            NULL AS ExpiryDate,
            NULL AS PendingExpiry,
            'Invalid Email or Vendor Code' AS Message;
        RETURN;
    END

    IF @VendorActive = 0
    BEGIN
        SELECT 
            0 AS Status,
            NULL AS UserId,
            @Email AS Email,
            NULL AS Token,
            NULL AS ExpiryDate,
            NULL AS PendingExpiry,
            'Vendor is inactive. Contact admin.' AS Message;
        RETURN;
    END

    ------------------------------
    -- 2. Check if user exists
    ------------------------------
    SELECT 
        @UserId = UserId,
        @IsActive = IsActive
    FROM [_vender].[User]
    WHERE Email = @Email
      AND IsDeleted = 0;

    IF @UserId IS NOT NULL AND @IsActive = 0
    BEGIN
        SELECT 
            0 AS Status,
            @UserId AS UserId,
            @Email AS Email,
            NULL AS Token,
            NULL AS ExpiryDate,
            NULL AS PendingExpiry,
            'User exists but is inactive. Contact admin.' AS Message;
        RETURN;
    END

    IF @UserId IS NOT NULL
    BEGIN
        SELECT 
            0 AS Status,
            @UserId AS UserId,
            @Email AS Email,
            NULL AS Token,
            NULL AS ExpiryDate,
            NULL AS PendingExpiry,
            'User already exists' AS Message;
        RETURN;
    END

    ------------------------------
    -- 3. Insert User
    ------------------------------
    INSERT INTO [_vender].[User] 
        (Email, PaswdHash, UserCode, CreatedAt, UpdatedAt, IsActive, IsDeleted)
    VALUES 
        (
            @Email,
            CONVERT(NVARCHAR(500), HASHBYTES('SHA2_256', @Password), 2),
            NULL,
            GETDATE(),
            GETDATE(),
            1,
            0
        );

    SET @UserId = SCOPE_IDENTITY();

    ------------------------------
    -- 4. Update Vendor with UserId
    ------------------------------
    UPDATE [_vender].[Vender]
    SET UserId = @UserId
    WHERE Email = @Email
      AND VenderCode = @VenderCode
      AND IsDeleted = 0;

    ------------------------------
    -- 5. Get Token Expiry Hours from Settings
    ------------------------------
SELECT @ExpiryHours = ExpiryTokenHrs
FROM [_vender].[Settings];

IF @ExpiryHours IS NULL
    SET @ExpiryHours = 48; 

    ------------------------------
    -- 6. Generate Token & Expiry Date
    ------------------------------
    SET @Token = NEWID(); -- simple token, replace with real JWT if needed
    SET @ExpiryDate = DATEADD(HOUR, @ExpiryHours, GETDATE());

    ------------------------------
    -- 7. Insert into UserToken table
    ------------------------------
    INSERT INTO [_vender].[UserToken]
    (
        UserId,
        UserCode,
        Email,
        Token,
        ExpiryDate,
        IsExpiry,
        CreatedDate
        -- PendingExpiry left NULL intentionally
    )
    VALUES
    (
        @UserId,
        @VenderCode,
        @Email,
        @Token,
        @ExpiryDate,
        0,
        GETDATE()
    );

    ------------------------------
    -- 8. Return Response
    ------------------------------
    SELECT 
        1 AS Status,
        @UserId AS UserId,
        @Email AS Email,
        @Token AS Token,
        @ExpiryDate AS ExpiryDate,
        NULL AS PendingExpiry,
        'Registration successful' AS Message;

END
