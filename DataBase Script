CREATE PROCEDURE [_vender].[SP_Barcode_Delete]
    @BarcodeId INT
AS
BEGIN
    SET NOCOUNT ON;

    IF NOT EXISTS (SELECT 1 FROM[_vender].[VenderItemBarcode] WHERE BarcodeId = @BarcodeId)
    BEGIN
        SELECT 0 AS Status, 'BarCode not found.' AS Message;
        RETURN;
    END
    DELETE FROM[_vender].[VenderItemBarcode]
    WHERE BarcodeId = @BarcodeId;

    SELECT 1 AS Status, 'BarCode deleted successfully.' AS Message;
END
GO
