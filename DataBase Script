CREATE PROCEDURE [_vender].[SP_VenderItems_AssignUnassign]
    @VenderCode NVARCHAR(100),
    @ItemCode NVARCHAR(100),
    @Action NVARCHAR(20)   -- ASSIGN / UNASSIGN
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @VenderId INT;
    DECLARE @ItemId INT;

    BEGIN TRY
        BEGIN TRANSACTION;

        -- =========================
        -- GET VENDOR ID
        -- =========================
        SELECT @VenderId = VenderId
        FROM [_vender].[Vender]
        WHERE VenderCode = @VenderCode
          AND IsDeleted = 0;

        IF (@VenderId IS NULL)
        BEGIN
            ROLLBACK TRANSACTION;
            SELECT 0 AS Status, 'Invalid Vendor Code.' AS Message;
            RETURN;
        END

        -- =========================
        -- GET ITEM ID
        -- =========================
        SELECT @ItemId = ItemId
        FROM [_vender].[Items]
        WHERE ItemCode = @ItemCode;

        IF (@ItemId IS NULL)
        BEGIN
            ROLLBACK TRANSACTION;
            SELECT 0 AS Status, 'Invalid Item Code.' AS Message;
            RETURN;
        END

        -- =========================
        -- ASSIGN ITEM
        -- =========================
        IF (UPPER(@Action) = 'ASSIGN')
        BEGIN
            IF EXISTS (
                SELECT 1 
                FROM [_vender].[VenderItems]
                WHERE VenderId = @VenderId
                  AND ItemId = @ItemId
            )
            BEGIN
                ROLLBACK TRANSACTION;
                SELECT 0 AS Status, 'Item already assigned.' AS Message;
                RETURN;
            END

            INSERT INTO [_vender].[VenderItems] (VenderId, ItemId, AssignedDate)
            VALUES (@VenderId, @ItemId, GETDATE());

            COMMIT TRANSACTION;
            SELECT 1 AS Status, 'Item assigned successfully.' AS Message;
            RETURN;
        END

        -- =========================
        -- UNASSIGN ITEM
        -- =========================
        IF (UPPER(@Action) = 'UNASSIGN')
        BEGIN
            IF NOT EXISTS (
                SELECT 1 
                FROM [_vender].[VenderItems]
                WHERE VenderId = @VenderId
                  AND ItemId = @ItemId
            )
            BEGIN
                ROLLBACK TRANSACTION;
                SELECT 0 AS Status, 'Item not assigned.' AS Message;
                RETURN;
            END

            DELETE FROM [_vender].[VenderItems]
            WHERE VenderId = @VenderId
              AND ItemId = @ItemId;

            COMMIT TRANSACTION;
            SELECT 1 AS Status, 'Item unassigned successfully.' AS Message;
            RETURN;
        END

      
        ROLLBACK TRANSACTION;
        SELECT 0 AS Status, 'Invalid Action. Use ASSIGN / UNASSIGN.' AS Message;

    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        SELECT 0 AS Status, ERROR_MESSAGE() AS Message;
    END CATCH
END
GO
