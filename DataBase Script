CREATE PROCEDURE [_vender].[SP_DeleteVender]
    @VenderId INT
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRANSACTION;

        
        IF NOT EXISTS (
            SELECT 1 
            FROM [_vender].[Vender]
            WHERE VenderId = @VenderId
              AND IsDeleted = 0
        )
        BEGIN
            ROLLBACK TRANSACTION;

            SELECT
                0 AS Status,                
                'Vender not found or already deleted.' AS Message,
                NULL AS VenderId;

            RETURN;
        END

        
        UPDATE [_vender].[Vender]
        SET 
            IsDeleted = 1,
            UpdatedDate = GETDATE()
        WHERE VenderId = @VenderId;

        COMMIT TRANSACTION;

        --
        SELECT
            1 AS Status,                    
            'Vender deleted successfully.' AS Message,
            @VenderId AS VenderId;

    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0
            ROLLBACK TRANSACTION;

        SELECT
            0 AS Status,                     
            ERROR_MESSAGE() AS Message,
            NULL AS VenderId;
    END CATCH
END
GO
