CREATE PROCEDURE [_vender].[SP_BlockUser]
(
    @UserId INT,
    @BlockedUserId INT
)
AS
BEGIN

BEGIN TRY

    IF EXISTS
    (
        SELECT 1 
        FROM [_vender].[BlockedUsers]
        WHERE UserId = @UserId
        AND BlockedUserId = @BlockedUserId
    )

    BEGIN

        DELETE FROM [_vender].[BlockedUsers]
        WHERE UserId = @UserId
        AND BlockedUserId = @BlockedUserId

        SELECT 
        'User Unblocked Successfully' AS Message,
        CAST(0 AS BIT) AS IsBlocked

    END
    ELSE
    BEGIN

        INSERT INTO [_vender].[BlockedUsers]
        (
            UserId,
            BlockedUserId
        )
        VALUES
        (
            @UserId,
            @BlockedUserId
        )

        SELECT 
        'User Blocked Successfully' AS Message,
        CAST(1 AS BIT) AS IsBlocked

    END

END TRY

BEGIN CATCH

    SELECT 
    ERROR_MESSAGE() AS Message,
    CAST(0 AS BIT) AS IsBlocked

END CATCH

END
GO
