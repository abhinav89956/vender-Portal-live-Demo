CREATE PROCEDURE [_vender].[SP_GetAllItems]
    @SearchItemCode NVARCHAR(100) = NULL,  
    @PageNumber INT = 1,                   
    @PageSize INT = 10                      
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        -- Validate page number and page size
        IF @PageNumber < 1 SET @PageNumber = 1;
        IF @PageSize < 1 SET @PageSize = 10;

        -- Calculate offset for pagination
        DECLARE @Offset INT = (@PageNumber - 1) * @PageSize;

        -- Get total count of matching items
        DECLARE @TotalCount INT;
        SELECT @TotalCount = COUNT(*) 
        FROM [_vender].[Items]
        WHERE (@SearchItemCode IS NULL OR ItemCode LIKE '%' + @SearchItemCode + '%');

        
        SELECT
            1 AS Status,
            'Success' AS Message,
            ItemID,
            ItemCode,
            ItemDescription,
            UPC,
            CreatedDate,
            @TotalCount AS TotalCount  
        FROM [_vender].[Items]
        WHERE (@SearchItemCode IS NULL OR ItemCode LIKE '%' + @SearchItemCode + '%')
        ORDER BY CreatedDate DESC
        OFFSET @Offset ROWS
