    SELECT 
        MessageId,
        ReceiverId,
        IsDelivered,
        IsSeen,
        SeenAt
    FROM [_vender].[MessageStatus]
    WHERE MessageId = @MessageId;

END TRY
BEGIN CATCH
    SELECT 
        ERROR_NUMBER() AS ErrorNumber,
        ERROR_MESSAGE() AS ErrorMessage;
END CATCH
