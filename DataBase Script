CREATE PROCEDURE [_vender].[SP_GetChatMessages]
(
    @User1 INT,  -- logged-in user
    @User2 INT   -- other contact
)
AS
BEGIN
    SELECT 
        M.MessageId,
        M.SenderId,
        M.ReceiverId,
        M.MessageText,
        M.MessageType,
        M.SentAt,

        -- 1 if message sent by logged-in user
        CASE WHEN M.SenderId = @User1 THEN 1 ELSE 0 END AS IsSent,

        -- MessageStatus fields
        ISNULL(MS.StatusId, 0) AS StatusId,
        ISNULL(MS.IsDelivered, 0) AS IsDelivered,
        ISNULL(MS.IsSeen, 0) AS IsSeen,
        MS.SeenAt

    FROM [_vender].[Messages] M
    LEFT JOIN [_vender].[MessageStatus] MS
        ON MS.MessageId = M.MessageId
        AND MS.ReceiverId = CASE WHEN M.SenderId = @User1 THEN @User2 ELSE @User1 END

    WHERE
        (M.SenderId = @User1 AND M.ReceiverId = @User2)
        OR
        (M.SenderId = @User2 AND M.ReceiverId = @User1)

    ORDER BY M.SentAt;
END;
