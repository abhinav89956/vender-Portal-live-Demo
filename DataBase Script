CREATE PROCEDURE [_vender].[SP_UpdateSeenStatus]
(
    @ReceiverId INT,
    @MessageId INT
)
AS
BEGIN
BEGIN TRY

    -- 1️⃣ Update MessageStatus
    UPDATE [_vender].[MessageStatus]
    SET 
        IsDelivered = 1,
        IsSeen = 1,
        SeenAt = GETDATE()
    WHERE 
        ReceiverId = @ReceiverId
        AND MessageId = @MessageId;

    -- 2️⃣ Update Notifications (ReceiverId base)
    UPDATE [_vender].[Notifications]
    SET IsRead = 1
    WHERE 
        ReceiverId = @ReceiverId
        AND IsRead = 0;

