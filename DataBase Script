CREATE   PROCEDURE [_vender].[SP_ToggleBlockUser]
(
    @UserId INT,
    @TargetUserId INT,
    @Action NVARCHAR(10)  -- 'Block' or 'Unblock'
)
AS
BEGIN
    BEGIN TRY
        IF @Action = 'Block'
        BEGIN
            -- Insert only if not already blocked
            IF NOT EXISTS (
                SELECT 1 FROM [_vender].[BlockedUsers]
                WHERE UserId = @UserId AND BlockedUserId = @TargetUserId
            )
            BEGIN
                INSERT INTO [_vender].[BlockedUsers] (UserId, BlockedUserId)
                VALUES (@UserId, @TargetUserId)
            END

            SELECT 'User Blocked Successfully' AS Message
        END
        ELSE IF @Action = 'Unblock'
        BEGIN
            DELETE FROM [_vender].[BlockedUsers]
            WHERE UserId = @UserId AND BlockedUserId = @TargetUserId

            SELECT 'User Unblocked Successfully' AS Message
        END
        ELSE
        BEGIN
            THROW 50000, 'Invalid Action. Use "Block" or "Unblock".', 1
        END
    END TRY
    BEGIN CATCH
        SELECT ERROR_MESSAGE() AS ErrorMessage
    END CATCH
END
