CREATE PROCEDURE [_vender].[SP_AddVenderWithLotStrict] @VenderCode NVARCHAR(50), @CodeDescription NVARCHAR(255), @Email NVARCHAR(255) AS BEGIN SET NOCOUNT ON; BEGIN TRY BEGIN TRANSACTION; DECLARE @ExistingVenderId INT; /* ✅ Duplicate VendorCode Check */ SELECT @ExistingVenderId = VenderId FROM [_vender].[Vender] WHERE VenderCode = @VenderCode AND IsDeleted = 0; IF @ExistingVenderId IS NOT NULL BEGIN ROLLBACK TRANSACTION; SELECT 0 AS Status, 'VenderCode already exists.' AS Message, @ExistingVenderId AS VenderId, NULL AS AssignedLotVender; RETURN; END /* ✅ Duplicate Email Check */ SELECT @ExistingVenderId = VenderId FROM [_vender].[Vender] WHERE Email = @Email AND IsDeleted = 0; IF @ExistingVenderId IS NOT NULL BEGIN ROLLBACK TRANSACTION; SELECT 0 AS Status, 'Email already exists.' AS Message, @ExistingVenderId AS VenderId, NULL AS AssignedLotVender; RETURN; END /* ✅ Concurrency Safe Lot Allocation */ DECLARE @LotVender NVARCHAR(50); SELECT TOP 1 @LotVender = LV.LotVenderCode FROM [_vender].[LotVender] LV WITH (UPDLOCK, HOLDLOCK) WHERE NOT EXISTS ( SELECT 1 FROM [_vender].[Vender] V WHERE V.LotVender = LV.LotVenderCode AND V.IsDeleted = 0 ) ORDER BY LV.LotId; IF @LotVender IS NULL BEGIN ROLLBACK TRANSACTION; SELECT 0 AS Status, 'No available LotVender. Please add more lots.' AS Message, NULL AS VenderId, NULL AS AssignedLotVender; RETURN; END /* ✅ Insert Vendor */ INSERT INTO [_vender].[Vender] ( VenderCode, CodeDescription, LotVender, InsertedDate, UpdatedDate, IsActive, IsVerifird, IsAgrementSigned, IsSignupCompleted, Email, IsDeleted ) VALUES ( @VenderCode, @CodeDescription, @LotVender, GETDATE(), NULL, 1, 0, 0, 0, @Email, 0 ); DECLARE @NewVenderId INT = SCOPE_IDENTITY(); COMMIT TRANSACTION; SELECT 1 AS Status, 'Vender added successfully.' AS Message, @NewVenderId AS VenderId, @LotVender AS AssignedLotVender; END TRY BEGIN CATCH IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION; SELECT 0 AS Status, ERROR_MESSAGE() AS Message, NULL AS VenderId, NULL AS AssignedLotVender; END CATCH END
GO
