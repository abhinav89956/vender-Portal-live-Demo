CREATE PROCEDURE [_vender].[SP_Items_Add]
    @ItemCode NVARCHAR(100),
    @ItemDescription NVARCHAR(500),
    @UPC BIGINT
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRANSACTION;

        
        IF EXISTS (SELECT 1 FROM [_vender].[Items] WHERE ItemCode = @ItemCode)
        BEGIN
            SELECT 0 AS Status, 'Item Code already exists.' AS Message;
            ROLLBACK TRANSACTION;
            RETURN;
        END

        
        CREATE TABLE #TempItems
        (
            ItemCode NVARCHAR(100),
            ItemDescription NVARCHAR(500),
            UPC BIGINT,
            CreatedDate DATETIME
        );

       
        INSERT INTO #TempItems
        (
