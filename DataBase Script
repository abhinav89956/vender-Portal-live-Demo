            ItemDescription,
            UPC,
            CreatedDate
        )
        VALUES
        (
            @ItemCode,
            @ItemDescription,
            @UPC,
            GETDATE()
        );

       
        INSERT INTO [_vender].[Items]
        (
            ItemCode,
            ItemDescription,
            UPC,
            CreatedDate
        )
        SELECT
            ItemCode,
            ItemDescription,
            UPC,
            CreatedDate
        FROM #TempItems;

        COMMIT TRANSACTION;

        SELECT 1 AS Status, 'Item added successfully.' AS Message;

    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;

        SELECT 
            0 AS Status,
            ERROR_MESSAGE() AS Message;
    END CATCH
END
