CREATE PROCEDURE [_vender].[SP_SendMessage]
(
    @SenderId INT,
    @ReceiverId INT,
    @MessageText NVARCHAR(MAX),
    @MessageType NVARCHAR(50)
)
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        DECLARE @MessageId INT;

        -- 1️⃣ Insert into Messages table
        INSERT INTO [_vender].[Messages] 
            (SenderId, ReceiverId, MessageText, MessageType, SentAt, CreatedAt)
        VALUES 
            (@SenderId, @ReceiverId, @MessageText, @MessageType, GETDATE(), GETDATE());

        SET @MessageId = SCOPE_IDENTITY();

        -- 2️⃣ Insert into MessageStatus
        INSERT INTO [_vender].[MessageStatus] 
            (MessageId, ReceiverId, IsSent, IsDelivered, IsSeen, SeenAt)
        VALUES 
            (@MessageId, @ReceiverId, 1, 0, 0, NULL);

        -- 3️⃣ Insert into Notifications (ReceiverId added)
  INSERT INTO [_vender].[Notifications] 
            (MessageId, ReceiverId, SenderId, IsRead, CreatedAt)
        VALUES 
            (@MessageId, @ReceiverId, @SenderId, 0, GETDATE());


        -- 4️⃣ Return inserted message with status
        SELECT 
            M.MessageId AS MessageId,
            M.SenderId AS SenderId,
            M.ReceiverId AS ReceiverId,
            M.MessageText AS MessageText,
            M.MessageType AS MessageType,
            M.SentAt AS SentAt,
            MS.IsSent AS IsSent,
            MS.IsDelivered AS IsDelivered,
            MS.IsSeen AS IsSeen
        FROM [_vender].[Messages] M
        INNER JOIN [_vender].[MessageStatus] MS
            ON M.MessageId = MS.MessageId
        WHERE M.MessageId = @MessageId;

    END TRY
    BEGIN CATCH
        SELECT 
            ERROR_NUMBER() AS ErrorNumber,
            ERROR_MESSAGE() AS ErrorMessage;
    END CATCH
END
